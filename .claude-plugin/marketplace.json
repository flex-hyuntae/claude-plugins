{
  "name": "flex-hyuntae-plugins",
  "owner": {
    "name": "flex-hyuntae"
  },
  "metadata": {
    "description": "Personal Claude Code plugin marketplace by flex-hyuntae",
    "version": "2026.03.27",
    "pluginRoot": "./plugins"
  },
  "plugins": [
    {
      "name": "git",
      "source": "./plugins/git",
      "description": "Conventional commit 형식의 커밋 메시지 생성, GitHub PR 자동 생성, stacked PR rebase 정리",
      "version": "2026.04",
      "keywords": [
        "git",
        "commit",
        "pull-request",
        "conventional-commit",
        "rebase",
        "stacked-pr"
      ]
    },
{
      "name": "code-review",
      "source": "./plugins/code-review",
      "description": "SOLID 원칙 기반 종합 코드 리뷰를 한국어로 수행하고 GitHub에 S1/S2/S3 심각도별 코멘트 작성",
      "version": "2026.03.23",
      "keywords": ["code-review", "solid", "react", "typescript", "github"]
    },
    {
      "name": "flex-workflow",
      "source": "./plugins/flex-workflow",
      "description": "flex 프로젝트 전용 워크플로우: QA/Prod 배포 PR, 패키지 로컬 테스트, i18n 변환, TIL 기록",
      "version": "2026.04",
      "keywords": [
        "deploy",
        "test-package",
        "i18n",
        "flex",
        "workflow",
        "til",
        "obsidian"
      ]
    },
    {
      "name": "drill",
      "source": "./plugins/drill",
      "description": "Spec/Concept 생성 → 티켓 준비 → Spec 동기화 → TC 생성까지의 개발 워크플로우 오케스트레이션",
      "version": "2026.04.21.1",
      "keywords": [
        "spec",
        "concept",
        "ticket",
        "review",
        "sync",
        "tc",
        "workflow",
        "orchestration",
        "drill",
        "interview",
        "stacked-pr",
        "batch"
      ]
    },
    {
      "name": "rules",
      "source": "./plugins/rules",
      "description": "코드 생성 및 리뷰 시 참고할 코딩 컨벤션과 성능 최적화 규칙 (37개 규칙)",
      "version": "2026.04.24.1",
      "keywords": [
        "rules",
        "conventions",
        "best-practices",
        "react",
        "typescript",
        "structure",
        "styling",
        "accessibility",
        "testing",
        "naming"
      ]
    }
  ]
}
